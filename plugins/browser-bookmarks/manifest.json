{
  "id": "browser-bookmarks",
  "name": {
    "en": "Browser Bookmarks",
    "zh-CN": "浏览器书签"
  },
  "version": "1.0.0",
  "description": {
    "en": "Search bookmarks from Chrome, Edge, Firefox, Brave",
    "zh-CN": "搜索 Chrome、Edge、Firefox、Brave 的书签"
  },
  "author": "AlgerClipboard",
  "icon": "ph:bookmark",
  "api_version": "1",
  "frontend": {
    "entry": "frontend/index.js"
  },
  "backend": {
    "library": "backend/browser_bookmarks_plugin"
  },
  "permissions": [
    "filesystem:read"
  ],
  "spotlight_modes": [
    {
      "id": "browser-bookmarks",
      "prefix": "bm",
      "global_search": true,
      "priority": 60
    }
  ],
  "hooks": [],
  "settings": {
    "prefix": {
      "type": "string",
      "label": {
        "en": "Spotlight Prefix",
        "zh-CN": "Spotlight 前缀"
      },
      "default": "bm"
    },
    "max_results": {
      "type": "number",
      "label": {
        "en": "Max Results",
        "zh-CN": "最大结果数"
      },
      "default": 20,
      "min": 5,
      "max": 100
    },
    "cache_ttl": {
      "type": "number",
      "label": {
        "en": "Cache TTL (min)",
        "zh-CN": "缓存刷新间隔(分钟)"
      },
      "default": 5,
      "min": 1,
      "max": 60
    }
  }
}
